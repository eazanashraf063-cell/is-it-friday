import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.*;
import org.springframework.http.ResponseEntity;
import java.util.Map;

/**
 * A sample Java Spring Boot Application for Hudha's Travel Consultancy.
 * This can be used to handle form submissions or simple API requests.
 */
@SpringBootApplication
@RestController
@RequestMapping("/api/contact")
public class Main {

    public static void main(String[] args) {
        SpringApplication.run(Main.class, args);
    }

    /**
     * Endpoint to handle travel inquiries.
     * In a real scenario, this would send an email or save to a database.
     */
    @PostMapping("/inquire")
    public ResponseEntity<String> handleInquiry(@RequestBody Map<String, String> payload) {
        String name = payload.get("name");
        String email = payload.get("email");
        String destination = payload.get("destination");

        // Logic for sending email or logging inquiry
        System.out.println("New Inquiry received from: " + name + " (" + email + ")");
        System.out.println("Destination of interest: " + destination);

        return ResponseEntity.ok("Thank you, " + name + "! Hudha will contact you shortly regarding your trip to " + destination + ".");
    }
}
